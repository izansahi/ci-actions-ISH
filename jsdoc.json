{
  "source": {
    "include": ["src", "index.js"],
    "includePattern": ".+\\.js(doc|x)?$",
    "excludePattern": "(^|/)node_modules(/|$)"
  },
  "opts": {
    "destination": "./docs",
    "recurse": true,
    "readme": "./README.md"
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  }
}
